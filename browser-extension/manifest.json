{
  "manifest_version": 3,
  "name": "StudyFlow Browser Class Logging",
  "version": "1.0.0",
  "description": "Privately logs approved audible class playback to the local StudyFlow desktop app.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:17384/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "StudyFlow Browser Class Logging"
  }
}
