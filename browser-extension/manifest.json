{
  "manifest_version": 3,
  "name": "StudyFlow Browser Companion",
  "version": "1.0.0",
  "description": "Privately logs approved class playback and reminds you when distracting sites pull you off plan.",
  "permissions": ["storage", "tabs", "notifications"],
  "host_permissions": ["http://127.0.0.1:17384/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "StudyFlow Browser Companion"
  }
}
